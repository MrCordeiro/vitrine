{
  "name": "vitrine",
  "version": "0.1.0",
  "description": "Play Store screenshot pipeline CLI: capture with Maestro, frame with sharp, publish via the Google Play Developer API.",
  "type": "module",
  "license": "MIT",
  "author": "Fernando Cordeiro",
  "bin": {
    "vitrine": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "execa": "^9.5.1",
    "jiti": "^2.4.2",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "^20.17.10",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  }
}
